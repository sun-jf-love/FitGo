	flex: 1;
	overflow-y: scroll;
}

.bg-gradient {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	z-index: -1;
}

.glass-card {
	border-radius: 20px;
	border-width: 1px;
	border-style: solid;
	backdrop-filter: blur(10px);
	box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

.header {
	margin-bottom: 24px;
	padding: 16px;
}

.greeting {
	font-size: 32px;
	font-weight: bold;
}

