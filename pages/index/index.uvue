	font-size: 56px;
	font-weight: bold;
}

.status-unit {
	font-size: 18px;
	margin-top: 4px;
}

.status-label {
	font-size: 14px;
	margin-bottom: 16px;
}

.progress-bar {
	width: 100%;
	height: 8px;
	border-radius: 4px;
	overflow: hidden;
	margin-bottom: 8px;
}

