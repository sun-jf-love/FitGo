	font-size: 12px;
}

.stats-row {
	flex-direction: row;
	gap: 16px;
	margin: 0 16px 16px 16px;
}

.stat-item {
	flex: 1;
	padding: 16px;
	align-items: center;
}

.stat-number {
	font-size: 28px;
	font-weight: bold;
}

.stat-label {
	font-size: 12px;
	margin-top: 4px;
}

.quick-actions {
	padding: 20px;
	margin: 0 16px 16px 16px;
}

.action-title {
	margin-bottom: 16px;
}

.action-title-text {
	font-size: 18px;
	font-weight: bold;
}

.sport-types {
	flex-direction: row;
	flex-wrap: wrap;
}

.sport-item {
	width: 25%;
	padding: 12px 0;
	align-items: center;
}

.sport-icon-wrap {
	width: 52px;
	height: 52px;
	border-radius: 16px;
	align-items: center;
	justify-content: center;
	margin-bottom: 8px;
	border-width: 1px;
	border-style: solid;
}

.sport-color-0 .sport-icon-wrap {
	background-color: rgba(57, 255, 126, 0.2);
	border-color: rgba(57, 255, 126, 0.4);
}

.sport-color-1 .sport-icon-wrap {
	background-color: rgba(0, 229, 255, 0.2);
	border-color: rgba(0, 229, 255, 0.4);
}

.sport-color-2 .sport-icon-wrap {
	background-color: rgba(255, 147, 0, 0.2);
	border-color: rgba(255, 147, 0, 0.4);
}

.sport-color-3 .sport-icon-wrap {
	background-color: rgba(255, 77, 77, 0.2);
	border-color: rgba(255, 77, 77, 0.4);
}

.sport-icon {
	font-size: 26px;
}

.sport-name {
	font-size: 12px;
}

.today-records {
	padding: 20px;
	margin: 0 16px 16px 16px;
}

.section-title {
	margin-bottom: 16px;
}

.section-title-text {
	font-size: 18px;
	font-weight: bold;
}

.empty-text {
	font-size: 14px;
	padding: 20px 0;
	align-items: center;
}

.record-item {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding: 14px 0;
	border-bottom-width: 1px;
	border-bottom-style: solid;
}

.record-left {
	flex-direction: column;
}

.record-type {
	font-size: 15px;
}

.record-duration {
	font-size: 13px;
	margin-top: 4px;
}

.record-time-text {
	font-size: 13px;
}

.record-btn {
	margin: 0 16px 24px 16px;
	padding: 16px;
	align-items: center;
}

.record-btn-text {
	font-size: 18px;
	font-weight: bold;
}
</style>