	font-size: 15px;
	font-weight: bold;
}

.modal-title {
	font-size: 16px;
	font-weight: bold;
}

.time-picker {
	height: 200px;
}

.picker-item {
	align-items: center;
	justify-content: center;
}

.picker-item-text {
	font-size: 16px;
}

.days-options {
	flex-direction: row;
	flex-wrap: wrap;
	gap: 12px;
	padding: 20px;
}

.day-option {
	width: 28%;
	padding: 14px;
	border-radius: 14px;
