	padding: 8px 18px;
	border-radius: 16px;
	border-width: 1px;
	border-style: solid;
}

.method-text {
	font-size: 13px;
	font-weight: bold;
}

.goal-input {
	flex-direction: row;
	align-items: center;
	gap: 10px;
}

.goal-btn {
	width: 30px;
	height: 30px;
	border-radius: 14px;
	align-items: center;
	justify-content: center;
	border-width: 1px;
	border-style: solid;
}

.goal-btn-text {
	font-size: 20px;
	font-weight: bold;
}

.goal-value-wrap {
	width: 52px;
	height: 30px;
	border-radius: 10px;
	align-items: center;
	justify-content: center;
	border-width: 1px;
	border-style: solid;
}

.goal-value {
	width: 52px;
	height: 30px;
	text-align: center;
	font-size: 14px;
}

.goal-unit {
	font-size: 13px;
}

.theme-options {
	flex-direction: row;
	gap: 12px;
}

.theme-btn {
	padding: 10px 24px;
	border-radius: 20px;
	border-width: 1px;
	border-style: solid;
}

.theme-text {
	font-size: 14px;
	font-weight: bold;
}

.modal-mask {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background-color: rgba(0, 0, 0, 0.7);
	align-items: flex-end;
	justify-content: center;
	z-index: 999;
}

.modal-content {
	width: 100%;
	border-radius: 20px 20px 0 0;
	border-width: 1px;
	border-style: solid;
}

.modal-header {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding: 18px;
	border-bottom-width: 1px;
	border-bottom-style: solid;
}

.modal-cancel {
	font-size: 15px;
}

