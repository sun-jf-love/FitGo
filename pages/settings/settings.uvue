<template>
	<view class="container">
		<view class="bg-gradient" :style="{ background: themeColors.bgGradient }"></view>
		
		<view class="glass-card section" :style="{ background: themeColors.cardBg, borderColor: themeColors.cardBorder }">
			<text class="section-title" :style="{ color: themeColors.textMuted }">提醒设置</text>
			
			<view class="setting-item" @click="showTimePicker">
				<text class="setting-label" :style="{ color: themeColors.text }">提醒时间</text>
				<view class="setting-value">
					<text class="setting-text" :style="{ color: themeColors.textMuted }">{{ settings.reminderTime }}</text>
					<text class="setting-arrow" :style="{ color: themeColors.textMuted }">&gt;</text>
				</view>
			</view>
			
			<view class="setting-item" @click="showDaysPicker">
				<text class="setting-label" :style="{ color: themeColors.text }">提醒日期</text>
				<view class="setting-value">
					<text class="setting-text" :style="{ color: themeColors.textMuted }">{{ daysText }}</text>
					<text class="setting-arrow" :style="{ color: themeColors.textMuted }">&gt;</text>
				</view>
			</view>
			
			<view class="setting-item">
				<text class="setting-label" :style="{ color: themeColors.text }">提醒方式</text>
				<view class="reminder-methods">
					<view 
						:class="['method-btn', { active: settings.reminderMethod === 'push' }]"
						:style="{ background: settings.reminderMethod === 'push' ? themeColors.primaryGlow : themeColors.inputBg }"
						@click="setReminderMethod('push')"
					>
						<text class="method-text" :style="{ color: settings.reminderMethod === 'push' ? themeColors.primary : themeColors.textMuted }">推送</text>
					</view>
					<view 
						:class="['method-btn', { active: settings.reminderMethod === 'inapp' }]"
						:style="{ background: settings.reminderMethod === 'inapp' ? themeColors.primaryGlow : themeColors.inputBg }"
						@click="setReminderMethod('inapp')"
					>
						<text class="method-text" :style="{ color: settings.reminderMethod === 'inapp' ? themeColors.primary : themeColors.textMuted }">弹窗</text>
					</view>
					<view 
						:class="['method-btn', { active: settings.reminderMethod === 'both' }]"
						:style="{ background: settings.reminderMethod === 'both' ? themeColors.primaryGlow : themeColors.inputBg }"
						@click="setReminderMethod('both')"
					>
						<text class="method-text" :style="{ color: settings.reminderMethod === 'both' ? themeColors.primary : themeColors.textMuted }">两者</text>
					</view>
				</view>
			</view>
		</view>
		
		<view class="glass-card section" :style="{ background: themeColors.cardBg, borderColor: themeColors.cardBorder }">
			<text class="section-title" :style="{ color: themeColors.textMuted }">运动目标</text>
			
			<view class="setting-item">
				<text class="setting-label" :style="{ color: themeColors.text }">每日目标时长</text>
				<view class="goal-input">
					<view class="goal-btn" :style="{ background: themeColors.inputBg, borderColor: themeColors.inputBorder }" @click="decreaseGoal">
						<text class="goal-btn-text" :style="{ color: themeColors.text }">-</text>
					</view>
					<view class="goal-value-wrap" :style="{ background: themeColors.inputBg, borderColor: themeColors.inputBorder }">
						<input 
							class="goal-value" 
							type="number" 
							v-model="dailyGoalInput"
							:style="{ color: themeColors.text, background: 'transparent' }"
							@blur="saveGoal"
						/>
					</view>
					<view class="goal-btn" :style="{ background: themeColors.inputBg, borderColor: themeColors.inputBorder }" @click="increaseGoal">
						<text class="goal-btn-text" :style="{ color: themeColors.text }">+</text>
					</view>
					<text class="goal-unit" :style="{ color: themeColors.textMuted }">分钟</text>
				</view>
			</view>
		</view>
		
		<view class="glass-card section" :style="{ background: themeColors.cardBg, borderColor: themeColors.cardBorder }">
			<text class="section-title" :style="{ color: themeColors.textMuted }">主题设置</text>
			
			<view class="setting-item">
				<text class="setting-label" :style="{ color: themeColors.text }">主题模式</text>
				<view class="theme-options">
					<view 
						:class="['theme-btn', { active: settings.theme === 'light' }]"
						:style="{ background: settings.theme === 'light' ? themeColors.primaryGlow : themeColors.inputBg, borderColor: settings.theme === 'light' ? themeColors.primary : themeColors.inputBorder }"
						@click="setTheme('light')"
					>
						<text class="theme-text" :style="{ color: settings.theme === 'light' ? themeColors.primary : themeColors.textMuted }">白天</text>
					</view>
					<view 
						:class="['theme-btn', { active: settings.theme === 'dark' }]"
						:style="{ background: settings.theme === 'dark' ? themeColors.primaryGlow : themeColors.inputBg, borderColor: settings.theme === 'dark' ? themeColors.primary : themeColors.inputBorder }"
						@click="setTheme('dark')"
					>
						<text class="theme-text" :style="{ color: settings.theme === 'dark' ? themeColors.primary : themeColors.textMuted }">夜晚</text>
					</view>
				</view>
			</view>
		</view>
		
		<view class="glass-card section" :style="{ background: themeColors.cardBg, borderColor: themeColors.cardBorder }">
			<text class="section-title" :style="{ color: themeColors.textMuted }">数据管理</text>
			
			<view class="setting-item" @click="exportData">
				<text class="setting-label" :style="{ color: themeColors.text }">导出数据</text>
				<view class="setting-value">
					<text class="setting-arrow" :style="{ color: themeColors.textMuted }">&gt;</text>
				</view>
			</view>
			
			<view class="setting-item" @click="clearData">
				<text class="setting-label-danger" :style="{ color: themeColors.error }">清空数据</text>
				<view class="setting-value">
					<text class="setting-arrow" :style="{ color: themeColors.textMuted }">&gt;</text>
				</view>
			</view>
		</view>
		
		<view class="glass-card section" :style="{ background: themeColors.cardBg, borderColor: themeColors.cardBorder }">
			<text class="section-title" :style="{ color: themeColors.textMuted }">关于</text>
			
			<view class="setting-item">
				<text class="setting-label" :style="{ color: themeColors.text }">版本</text>
				<view class="setting-value">
					<text class="setting-text" :style="{ color: themeColors.textMuted }">v1.0.0</text>
				</view>
			</view>
		</view>
		
		<view class="modal-mask" v-if="showTimeModal || showDaysModal" @click="closeAll">
			<view class="modal-content" @click.stop :style="{ background: themeColors.modalBg, borderColor: themeColors.modalBorder }">
				<view class="modal-header">
					<text class="modal-cancel" :style="{ color: themeColors.textMuted }" @click="closeTimePicker">取消</text>
					<text class="modal-title" :style="{ color: themeColors.text }">{{ showTimeModal ? '选择时间' : '选择日期' }}</text>
					<text class="modal-confirm" :style="{ color: themeColors.primary }" @click="showTimeModal ? confirmTime() : confirmDays()">确定</text>
				</view>
				
				<picker-view v-if="showTimeModal" class="time-picker" :value="timePickerValue" @change="onTimeChange">
					<picker-view-column>
						<view v-for="(hour, index) in hours" :key="index" class="picker-item">
							<text class="picker-item-text" :style="{ color: themeColors.text }">{{ hour }}时</text>
						</view>
					</picker-view-column>
					<picker-view-column>
						<view v-for="(minute, index) in minutes" :key="index" class="picker-item">
							<text class="picker-item-text" :style="{ color: themeColors.text }">{{ minute }}分</text>
						</view>
					</picker-view-column>
				</picker-view>
				
				<view v-if="showDaysModal" class="days-options">
					<view 
						v-for="(day, index) in weekDays" 
						:key="index"
						:class="['day-option', 'day-color-' + (index % 4), { active: selectedDays.includes(index + 1) }]"
						:style="{ background: selectedDays.includes(index + 1) ? themeColors.primaryGlow : themeColors.inputBg }"
						@click="toggleDay(index + 1)"
					>
						<text class="day-text" :style="{ color: selectedDays.includes(index + 1) ? themeColors.primary : themeColors.textMuted }">{{ day }}</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { getSettings, saveSettings, exportData, type UserSettings } from '../../utils/storage.uts'
import { getCurrentTheme, getThemeColors, type ThemeColors } from '../../utils/theme.uts'

const settings = ref<UserSettings>({
	reminderTime: '08:00',
	reminderDays: [1, 2, 3, 4, 5],
	reminderMethod: 'both',
	dailyGoal: 30,
	sportTypes: [],
	theme: 'dark'
})

const dailyGoalInput = ref(30)
const showTimeModal = ref(false)
const showDaysModal = ref(false)
const themeColors = ref<ThemeColors>(getThemeColors('dark'))

const hours = ref<string[]>([])
const minutes = ref<string[]>([])
const timePickerValue = ref<number[]>([8, 0])

const weekDays = ref(['周一', '周二', '周三', '周四', '周五', '周六', '周日'])
const selectedDays = ref<number[]>([])

function initSettings() {
	const data = getSettings()
	settings.value = data
	dailyGoalInput.value = data.dailyGoal
	
	for (let i = 0; i < 24; i++) {
		hours.value.push(String(i).padStart(2, '0'))
	}
	for (let i = 0; i < 60; i++) {
		minutes.value.push(String(i).padStart(2, '0'))
	}
	
	const timeParts = data.reminderTime.split(':')
	timePickerValue.value = [parseInt(timeParts[0]), parseInt(timeParts[1])]
	
	selectedDays.value = [...data.reminderDays]
	
	themeColors.value = getThemeColors(data.theme)
}

const daysText = computed((): string => {
	if (selectedDays.value.length === 7) {
		return '每天'
	}
	if (selectedDays.value.length === 5 && 
		selectedDays.value.includes(1) && selectedDays.value.includes(2) &&
		selectedDays.value.includes(3) && selectedDays.value.includes(4) &&
		selectedDays.value.includes(5)) {
		return '工作日'
	}
	if (selectedDays.value.length === 2 && 
		selectedDays.value.includes(6) && selectedDays.value.includes(7)) {
		return '周末'
	}
	return `${selectedDays.value.length}天/周`
})

function showTimePicker() {
	showTimeModal.value = true
}

function closeTimePicker() {
	showTimeModal.value = false
}

function closeDaysPicker() {
	showDaysModal.value = false
}

function closeAll() {
	showTimeModal.value = false
	showDaysModal.value = false
}

function onTimeChange(e: { detail: { value: number[] } }) {
	timePickerValue.value = e.detail.value
}

function confirmTime() {
	const hour = hours.value[timePickerValue.value[0]]
	const minute = minutes.value[timePickerValue.value[1]]
	settings.value.reminderTime = `${hour}:${minute}`
	saveSettings(settings.value)
	closeTimePicker()
}

function showDaysPicker() {
	showDaysModal.value = true
}

function toggleDay(day: number) {
	const index = selectedDays.value.indexOf(day)
	if (index > -1) {
		if (selectedDays.value.length > 1) {
			selectedDays.value.splice(index, 1)
		}
	} else {
		selectedDays.value.push(day)
		selectedDays.value.sort()
	}
}

function confirmDays() {
	settings.value.reminderDays = [...selectedDays.value]
	saveSettings(settings.value)
	closeDaysPicker()
}

function setReminderMethod(method: 'push' | 'inapp' | 'both') {
	settings.value.reminderMethod = method
	saveSettings(settings.value)
}

function setTheme(theme: 'light' | 'dark') {
	settings.value.theme = theme
	saveSettings(settings.value)
	themeColors.value = getThemeColors(theme)
	uni.$emit('themeChange', theme)
}

function decreaseGoal() {
	if (dailyGoalInput.value > 5) {
		dailyGoalInput.value -= 5
		saveGoal()
	}
}

function increaseGoal() {
	if (dailyGoalInput.value < 180) {
		dailyGoalInput.value += 5
		saveGoal()
	}
}

function saveGoal() {
	if (dailyGoalInput.value < 5) {
		dailyGoalInput.value = 5
	}
	if (dailyGoalInput.value > 180) {
		dailyGoalInput.value = 180
	}
	settings.value.dailyGoal = dailyGoalInput.value
	saveSettings(settings.value)
}

function exportData() {
	const data = exportData()
	uni.setStorageSync('fitgo_export', data)
	uni.showModal({
		title: '导出成功',
		content: '数据已导出，是否查看？',
		success: (res) => {
			if (res.confirm) {
				uni.showToast({
					title: '请在控制台查看导出数据',
					icon: 'none'
				})
				console.log('Export Data:', data)
			}
		}
	})
}

function clearData() {
	uni.showModal({
		title: '确认清空',
		content: '确定要清空所有运动数据吗？此操作不可恢复。',
		success: (res) => {
			if (res.confirm) {
				uni.clearStorageSync()
				uni.reLaunch({
					url: '/pages/index/index'
				})
			}
		}
	})
}

onShow(() => {
	initSettings()
})
</script>

