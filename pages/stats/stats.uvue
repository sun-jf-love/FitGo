	height: 180px;
}

.chart-bars {
	flex-direction: row;
	align-items: flex-end;
	justify-content: space-around;
	height: 150px;
	padding-bottom: 10px;
}

.chart-bar-item {
	flex-direction: column;
	align-items: center;
}

.bar-container {
	height: 120px;
