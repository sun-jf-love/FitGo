	flex: 1;
}

.record-type {
	font-size: 14px;
	color: #FFFFFF;
	font-weight: bold;
}

.record-date {
	font-size: 12px;
	color: rgba(255, 255, 255, 0.7);
	margin-top: 4px;
}

.record-stats {
	align-items: flex-end;
}

.record-duration {
	font-size: 14px;
	color: #34D399;
